{
  "name": "pavelgheorghe/project-remote-sync",
  "description": "Project Remote Sync",
  "keywords": ["project", "deploy"],
  "type": "library",
  "require": {
    "php": ">=7.4.0",
    "symfony/framework-bundle": "^5.4",
    "guzzlehttp/guzzle": "^7.8",
    "symfony/yaml": "^5.4",
    "ext-json": "*",
    "sunra/php-simple-html-dom-parser": "1.5.3",
    "concrete5/dependency-patches": "^1.7",
    "ext-fileinfo": "*",
    "sabberworm/php-css-parser": "^8.5",
    "ext-http": "*"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/PavelGheorghe/php-simple-html-dom-parser"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "RequirementsChecker\\": "requirements-checker/"
    }
  },
  "config": {
    "allow-plugins": {
      "mlocati/composer-patcher": true
    }
  }
}
